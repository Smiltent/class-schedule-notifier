
<div class="main">
    <h1><a href="/"><span id="errorCode"></span> | click to return back</a></h1>
    <p><span id="errorMessage"></span></p>
</div>

<script>
    // idk how else to do it, but this is WAY funnier
    const errorCodes = {
        " ": "error not provided, i blame you",
        
        "400": "bad request",
        "401": "unauthorized; you aren't logged in",
        "402": "you didn't pay me, i accept eban, paypal, crypto & food",
        "403": "forbidden; you need permission to access this page",
        "404": "page not found",
        "405": "method not allowed",
        "406": "not acceptable",
        "408": "request timeout",
        "410": "gone, like my father",
        "418": "i'm a teapot",
        "429": "ratelimited 😡😡😡😡😡",

        "500": "internal server error; most likely database went down",
        "503": "service unavailable; we are getting ddosed",
    }

    const err = "<%= httpStatus %>"
    document.getElementById("errorCode").innerText = err
    document.getElementById("errorMessage").innerText = errorCodes[err]
</script>
